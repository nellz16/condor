# ── Required ─────────────────────────────────────────
# Create a bot: https://t.me/BotFather
TELEGRAM_TOKEN=

# Get your ID: https://t.me/userinfobot
ADMIN_USER_ID=

# ── Hummingbot API (set by make setup) ───────────────
# DEPLOY_HUMMINGBOT_API=true

# ── Web Dashboard (optional) ─────────────────────────
# Full public URL for the dashboard (include port if needed).
# Used for Telegram /web links AND as the server bind port.
# Examples: http://myserver.com:8088, https://dashboard.example.com
# WEB_URL=http://localhost:8088


# ── MemeScout AI (optional, paper-only by default) ─────
# Safe defaults: no real trading, no private key, no exchange key required.
MEMESCOUT_PAPER_ONLY=true
MEMESCOUT_DB_PATH=data/memescout_ai.sqlite
MEMESCOUT_PAPER_BALANCE_USDC=100
MEMESCOUT_MAX_SIGNALS_PER_HOUR=6
MEMESCOUT_MAX_CANDIDATES_STORED_PER_HOUR=100
MEMESCOUT_MAX_DEX_REQUESTS_PER_MINUTE=50
MEMESCOUT_ENABLE_DEX_SEARCH=false
MEMESCOUT_DUPLICATE_SIGNAL_WINDOW_SECONDS=3600
MEMESCOUT_DEX_REQUEST_MIN_INTERVAL_SECONDS=1.05
MEMESCOUT_LLM_MAX_CALLS_PER_HOUR=20
MEMESCOUT_SCAN_INTERVAL_SECONDS=300
MEMESCOUT_TRADE_SIZE_USDC=10
MEMESCOUT_ENTRY_MODE=
MEMESCOUT_EXIT_MODE=auto
MEMESCOUT_AUTO_MAX_OPEN_POSITIONS=3
MEMESCOUT_AUTO_TRADE_SIZE_USDC=10
MEMESCOUT_AUTO_MIN_SCORE=65
MEMESCOUT_AUTO_MAX_RUG_RISK=25
MEMESCOUT_AUTO_COOLDOWN_SAME_TOKEN_SECONDS=7200
MEMESCOUT_AUTO_REQUIRE_STRATEGY_CONFIRMATION=false
MEMESCOUT_MAX_HOLD_MINUTES=60
MEMESCOUT_MOMENTUM_DECAY_EXIT=true
MEMESCOUT_LIQUIDITY_DROP_EXIT=true
MEMESCOUT_LIQUIDITY_DROP_EXIT_PCT=35
MEMESCOUT_SELL_PRESSURE_EXIT=true
MEMESCOUT_SELL_PRESSURE_RATIO_EXIT=1.4
MEMESCOUT_STALE_PRICE_EXIT_MINUTES=15
MEMESCOUT_STALE_PRICE_ACTION=mark_stale
MEMESCOUT_SLIPPAGE_BPS=150
MEMESCOUT_STOP_LOSS_PCT=-35
MEMESCOUT_MONITOR_ENABLED=true
MEMESCOUT_MONITOR_INTERVAL_SECONDS=60
MEMESCOUT_TRAILING_STOP_PCT=30
MEMESCOUT_ALLOW_RISK_REDUCING_CLOSES_DURING_EMERGENCY=true

# Optional LLM explainer. If no key is set, MemeScout runs in rule-based mode.
# Supported: openai, openrouter, gemini
LLM_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional Solana enrichment. MemeScout runs without Helius.
HELIUS_API_KEY=

# ── Koyeb Free deployment (optional) ───────────────
KOYEB_FREE_MODE=false
PORT=8000
MEMESCOUT_LOW_MEMORY_MODE=false
MEMESCOUT_DISABLE_FULL_HUMMINGBOT_API=false
MEMESCOUT_AUTOSTART_SCANNER=false
MEMESCOUT_AUTOSTART_MONITOR=false
